   "source": [
    "x = np.linspace(-3,3,20)\n",
    "y = np.linspace(-3,3,20)\n",
    "\n",
    "X,Y = np.meshgrid(x,y)\n",
    "\n",
    "U = X\n",
    "V = Y\n",
    "\n",
    "plt.quiver(X,Y,U,V)\n",
    "plt.axis(\"equal\")\n",
    "plt.show()"
   ]
